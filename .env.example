# ============================================
# YouTube Audiobook Pipeline - Environment
# ============================================
# Copy this file to .env and fill in your values

# --- AI Text Generation ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- YouTube API ---
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CLIENT_SECRETS_FILE=config/client_secrets.json

# --- TTS Engine ---
# Options: vieneu | vbee | f5tts | edge
TTS_ENGINE=vieneu
# VieNeu-TTS mode: standard | turbo | remote
VIENEU_MODE=standard
VIENEU_EMOTION=storytelling
# Voice preset (Trúc Ly is default Northern Female)
VIENEU_VOICE_PRESET=truc_ly

# --- Channel Info ---
CHANNEL_NAME=My Audiobook Channel
CHANNEL_EMAIL=your-email@gmail.com

# --- Database ---
DATABASE_URL=postgresql://user:pass@localhost:5432/audiobook

# --- Storage ---
STORAGE_DIR=./data
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- Orchestrator ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
